# ─────────────────────────────────────────────────────────────
# PFKS — Ortam Değişkenleri
# Bu dosyayı .env.local olarak kopyalayın ve değerleri doldurun.
# .env.local dosyası asla Git'e commit edilmez (.gitignore'da).
# ─────────────────────────────────────────────────────────────

# Gemini API Anahtarı
# Geliştirme: .env.local dosyasına ekle (sadece local dev için)
# Production (Vercel): Dashboard > Settings > Environment Variables
GEMINI_API_KEY=your_gemini_api_key_here

# Sadece local dev proxy için (server.ts)
# Production'da Vercel serverless function kullanır
ALLOWED_ORIGIN=http://localhost:3000
